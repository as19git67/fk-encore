# ──────────────────────────────────────────────────────────────────────────────
# Vivanty – Docker Compose Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust the values for your environment.
#
#   cp docker-compose.env.example .env
#   docker compose up -d
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Main Application ─────────────────────────────────────────────────────────

# Port the app is accessible on the host
APP_PORT=8080

# Initial admin account (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me-please

# WebAuthn / Passkey configuration
# RP_ID = domain without protocol/port, RP_ORIGIN = full URL the browser uses
RP_ID=localhost
RP_NAME=Vivanty App
RP_ORIGIN=http://localhost:8080

# Database type: sqlite (default, simple) or postgres
DB_TYPE=sqlite

# Face detection
ENABLE_LOCAL_FACES=true
FACE_DISTANCE_THRESHOLD=0.42

# ── Embedding Service ────────────────────────────────────────────────────────

# Models (defaults are lightweight CPU-friendly choices)
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
DINO_MODEL_NAME=facebook/dinov2-base
EMBEDDING_LOG_LEVEL=INFO

# Password for the embedding service's PostgreSQL database
EMBEDDING_DB_PASSWORD=postgres
