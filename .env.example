# Initial admin user credentials
# These are used to seed the database on first startup.
# Change these values before deploying to production!
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=geheim
# WebAuthn / Passkey configuration
# RP_ID must match the domain where the app is served (no protocol, no port)
# RP_ORIGIN must match the full origin the browser uses (protocol + domain + port)
RP_ID=localhost
RP_NAME=FK Encore App
RP_ORIGIN=http://localhost:5173

# Photo storage configuration
PHOTO_UPLOAD_DIR=uploads/photos

# Face detection configuration
ENABLE_LOCAL_FACES=true
FACE_DISTANCE_THRESHOLD=0.42

# Database configuration
# DB_TYPE can be 'sqlite' or 'postgres'
DB_TYPE=sqlite

# SQLite configuration (only used when DB_TYPE=sqlite)
# Path to SQLite database file (relative to project root or absolute)
SQLITE_DB_PATH=./data/app.db

# PostgreSQL configuration (only used when DB_TYPE=postgres)
# Connection string format: postgres://user:password@host:port/database
# Or specify individual parameters:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=fk_encore
# Or use a full connection string (overrides individual parameters if set):
# POSTGRES_CONNECTION_STRING=postgres://user:password@host:port/database
